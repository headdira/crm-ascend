---
const stars = Array.from({ length: 48 }, (_, id) => ({
  id,
  left: ((id * 37 + 13) % 97) + 1.5,
  top: ((id * 53 + 7) % 94) + 3,
  size: id % 4 === 0 ? 2.5 : id % 3 === 0 ? 2 : 1.5,
  delay: (id % 12) * 0.35,
  duration: 2.8 + (id % 7) * 0.55,
  drift: id % 5,
}));
---

<div class="pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden>
  {
    stars.map((star) => (
      <span
        class={`sales-star sales-star--drift-${star.drift}`}
        style={{
          left: `${star.left}%`,
          top: `${star.top}%`,
          width: `${star.size}px`,
          height: `${star.size}px`,
          animationDelay: `${star.delay}s`,
          animationDuration: `${star.duration}s, ${star.duration * 1.4}s`,
        }}
      />
    ))
  }
</div>
