---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import AdsQuizFunnel from "@/components/sales/AdsQuizFunnel";
import ConsentScripts from "@/components/sales/ConsentScripts";
import AttributionCapture from "@/components/sales/AttributionCapture";
import { getSiteUrl } from "@/lib/site-url";

const siteUrl = getSiteUrl();
---

<Layout
  title="Diagnóstico rápido"
  description="Responda em poucos passos e veja se o Ascend Club é para você."
  canonical={`${siteUrl}/form`}
>
  <AttributionCapture client:load />
  <AdsQuizFunnel client:load />
  <ConsentScripts client:idle />
</Layout>
