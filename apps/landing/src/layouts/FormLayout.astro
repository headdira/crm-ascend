---
import "../styles/globals.css";
import SalesJsonLd from "@/components/sales/SalesJsonLd";
import CookieConsent from "@/components/sales/CookieConsent";
import ConsentScripts from "@/components/sales/ConsentScripts";
import { getSiteUrl } from "@/lib/site-url";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Diagnóstico rápido",
  description = "Responda em poucos passos e veja se o Ascend Club é para você.",
  canonical,
} = Astro.props;

const siteUrl = getSiteUrl();
const pageTitle = title === "Ascend Club" ? title : `${title} | Ascend Club`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="canonical"
      href={canonical ?? `${siteUrl}${Astro.url.pathname}`}
    />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, follow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-inter-family: "Inter", ui-sans-serif, system-ui, sans-serif;
        --font-funnel-display: "Oswald", "Inter", ui-sans-serif, system-ui, sans-serif;
      }
      html,
      body {
        background: #fff;
      }
    </style>
  </head>
  <body
    class="form-funnel font-inter antialiased bg-white text-[#111]"
    style="font-family: var(--font-inter-family)"
  >
    <div class="form-funnel-shell relative min-h-screen bg-white overflow-x-hidden">
      <SalesJsonLd />
      <slot />
      <CookieConsent client:idle />
      <ConsentScripts client:idle />
    </div>
    <script>
      import "@/scripts/site-init";
    </script>
  </body>
</html>
